              "blocks": {
                "faq_a1": {
                  "type": "text",
                  "settings": {
                    "text": "<p>BabyShield is designed for babies aged 6 months to 3 years — the crawling and early walking stages. The adjustable straps ensure a comfortable, secure fit as your baby grows.</p>",
                    "width": "100%", "max_width": "normal", "alignment": "left",
                    "type_preset": "paragraph", "font": "var(--font-body--family)",
                    "font_size": "", "line_height": "normal", "letter_spacing": "normal",
                    "case": "none", "wrap": "pretty", "color": "var(--color-foreground)",
