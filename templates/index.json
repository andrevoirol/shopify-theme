              }
            },
            "faq_q2": {
              "type": "_accordion-row",
              "blocks": {
                "faq_a2": {
                  "type": "text",
                  "settings": {
                    "text": "<p>BabyShield is designed for active daytime use — crawling, walking, and play. We recommend removing it during nap time and sleep for your baby's comfort.</p>",
